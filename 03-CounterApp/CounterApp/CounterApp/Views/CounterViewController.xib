<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23094" targetRuntime="AppleSDK" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreaLayoutGuides="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23084"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CounterViewController" customModule="CounterApp" customModuleProvider="target">
            <connections>
                <outlet property="view" destination="i5M-Pr-FkT" id="sfx-zR-JGt"/>
                <outlet property="countLabel" destination="cLb-eF-gH2" id="cnt-out-001"/>
                <outlet property="incrementButton" destination="iBt-uV-wX6" id="inc-out-001"/>
                <outlet property="decrementButton" destination="dBt-mN-oP4" id="dec-out-001"/>
                <outlet property="resetButton" destination="rBt-qR-sT5" id="rst-out-001"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="i5M-Pr-FkT">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- タイトルラベル -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="カウンターアプリ" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tLb-aB-cD1">
                    <rect key="frame" x="97" y="103" width="199" height="29"/>
                    <fontDescription key="fontDescription" type="boldSystem" pointSize="24"/>
                    <nil key="textColor"/>
                    <nil key="highlightedColor"/>
                </label>
                <!-- カウント表示ラベル -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="0" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cLb-eF-gH2">
                    <rect key="frame" x="153" y="370" width="87" height="86"/>
                    <constraints>
                        <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="100" id="w-cnt-001"/>
                    </constraints>
                    <fontDescription key="fontDescription" style="UICTFontTextStyleTitle0" pointSize="72"/>
                    <color key="textColor" systemColor="labelColor"/>
                    <nil key="highlightedColor"/>
                </label>
                <!-- ボタン用 StackView -->
                <stackView opaque="NO" contentMode="scaleToFill" distribution="fillEqually" spacing="20" translatesAutoresizingMaskIntoConstraints="NO" id="sVw-iJ-kL3">
                    <rect key="frame" x="66" y="496" width="261" height="50"/>
                    <subviews>
                        <!-- −ボタン -->
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="dBt-mN-oP4">
                            <rect key="frame" x="0.0" y="0.0" width="73.7" height="50"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="50" id="h-dec-001"/>
                            </constraints>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                            <state key="normal" title="−"/>
                        </button>
                        <!-- Resetボタン -->
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="rBt-qR-sT5">
                            <rect key="frame" x="93.7" y="0.0" width="73.7" height="50"/>
                            <fontDescription key="fontDescription" type="system" pointSize="17"/>
                            <state key="normal" title="Reset"/>
                        </button>
                        <!-- +ボタン -->
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="iBt-uV-wX6">
                            <rect key="frame" x="187.3" y="0.0" width="73.7" height="50"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                            <state key="normal" title="＋"/>
                        </button>
                    </subviews>
                </stackView>
            </subviews>
            <viewLayoutGuide key="safeArea" id="fnl-2z-Ty3"/>
            <color key="backgroundColor" systemColor="systemBackgroundColor"/>
            <constraints>
                <!-- タイトル: 上端から40pt、中央揃え -->
                <constraint firstItem="tLb-aB-cD1" firstAttribute="top" secondItem="fnl-2z-Ty3" secondAttribute="top" constant="40" id="tp-ttl-001"/>
                <constraint firstItem="tLb-aB-cD1" firstAttribute="centerX" secondItem="i5M-Pr-FkT" secondAttribute="centerX" id="cx-ttl-001"/>
                <!-- カウント: 画面中央よりやや上、中央揃え -->
                <constraint firstItem="cLb-eF-gH2" firstAttribute="centerY" secondItem="i5M-Pr-FkT" secondAttribute="centerY" constant="-50" id="cy-cnt-001"/>
                <constraint firstItem="cLb-eF-gH2" firstAttribute="centerX" secondItem="i5M-Pr-FkT" secondAttribute="centerX" id="cx-cnt-001"/>
                <!-- ボタン: カウントラベルの下40pt、中央揃え -->
                <constraint firstItem="sVw-iJ-kL3" firstAttribute="top" secondItem="cLb-eF-gH2" secondAttribute="bottom" constant="40" id="tp-stk-001"/>
                <constraint firstItem="sVw-iJ-kL3" firstAttribute="centerX" secondItem="i5M-Pr-FkT" secondAttribute="centerX" id="cx-stk-001"/>
            </constraints>
        </view>
    </objects>
    <resources>
        <systemColor name="labelColor">
            <color red="0.0" green="0.0" blue="0.0" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
    </resources>
</document>
